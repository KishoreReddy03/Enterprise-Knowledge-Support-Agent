# Stripe Support Agent - Environment Variables
# Copy this file to .env and fill in your values


# REQUIRED - API Keys (no defaults, must be set)


# Anthropic API key for Claude models
ANTHROPIC_API_KEY=

# Supabase configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Qdrant vector database
QDRANT_URL=
QDRANT_API_KEY=

# Upstash Redis
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=

# Langfuse observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=


# OPTIONAL - Have sensible defaults


# Langfuse host (default: https://cloud.langfuse.com)
# LANGFUSE_HOST=https://cloud.langfuse.com

# Environment (default: development)
# ENVIRONMENT=development

# Model configuration
# HAIKU_MODEL=claude-haiku-4-5-20251001
# SONNET_MODEL=claude-sonnet-4-6
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# Qdrant collection names
# QDRANT_DOCS_COLLECTION=stripe_docs
# QDRANT_ISSUES_COLLECTION=stripe_github_issues
# QDRANT_STACKOVERFLOW_COLLECTION=stripe_stackoverflow

# Confidence thresholds (0.0 - 1.0)
# CONFIDENCE_HIGH_THRESHOLD=0.90
# CONFIDENCE_MEDIUM_THRESHOLD=0.75
# CONFIDENCE_LOW_THRESHOLD=0.60
# RETRIEVAL_SIMILARITY_THRESHOLD=0.75

# Agent configuration
# MAX_AGENT_RETRIES=2

# GitHub API access (optional - increases rate limit from 60 to 5000 req/hour)
# GITHUB_TOKEN=ghp_your-github-token-here
